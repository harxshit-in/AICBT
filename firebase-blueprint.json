{
  "entities": {
    "Topic": {
      "title": "Topic",
      "description": "A community discussion topic",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the topic" },
        "imageUrl": { "type": "string", "description": "URL of the topic image" },
        "status": { "type": "string", "enum": ["open", "closed"], "description": "Status of the topic" },
        "createdBy": { "type": "string", "description": "User ID of the admin who created it" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" }
      },
      "required": ["name", "status", "createdBy", "createdAt"]
    },
    "TopicMember": {
      "title": "TopicMember",
      "description": "A member of a community topic",
      "type": "object",
      "properties": {
        "topicId": { "type": "string", "description": "ID of the topic" },
        "userId": { "type": "string", "description": "ID of the user" },
        "role": { "type": "string", "enum": ["member", "approved_poster"], "description": "Role in the topic" },
        "status": { "type": "string", "enum": ["joined", "pending_approval"], "description": "Status of membership" }
      },
      "required": ["topicId", "userId", "role", "status"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in a topic",
      "type": "object",
      "properties": {
        "topicId": { "type": "string", "description": "ID of the topic" },
        "userId": { "type": "string", "description": "ID of the user" },
        "type": { "type": "string", "enum": ["text", "poll", "image"], "description": "Type of message" },
        "content": { "type": "string", "description": "Text content or image URL" },
        "pollData": { "type": "object", "description": "Poll data if type is poll" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" }
      },
      "required": ["topicId", "userId", "type", "createdAt"]
    },
    "Reaction": {
      "title": "Reaction",
      "description": "A reaction to a message",
      "type": "object",
      "properties": {
        "messageId": { "type": "string", "description": "ID of the message" },
        "userId": { "type": "string", "description": "ID of the user" },
        "emoji": { "type": "string", "description": "The emoji" }
      },
      "required": ["messageId", "userId", "emoji"]
    },
    "MockTest": {
      "title": "MockTest",
      "description": "A mock exam for students",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the test" },
        "subject": { "type": "string", "description": "Subject of the test" },
        "questions": { "type": "array", "description": "List of questions" },
        "createdBy": { "type": "string", "description": "User ID of creator" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["title", "subject", "questions", "createdBy", "createdAt"]
    },
    "TestResult": {
      "title": "TestResult",
      "description": "Result of a mock test",
      "type": "object",
      "properties": {
        "testId": { "type": "string", "description": "ID of the test" },
        "userId": { "type": "string", "description": "ID of the student" },
        "score": { "type": "number", "description": "Final score" },
        "feedback": { "type": "string", "description": "AI feedback" },
        "answers": { "type": "array", "description": "User's answers" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["testId", "userId", "score", "answers", "createdAt"]
    },
    "Bounty": {
      "title": "Bounty",
      "description": "A doubt-solving bounty",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Question title" },
        "description": { "type": "string", "description": "Question details" },
        "reward": { "type": "number", "description": "Point reward" },
        "status": { "type": "string", "enum": ["open", "solved"], "description": "Status" },
        "userId": { "type": "string", "description": "ID of asker" },
        "solverId": { "type": "string", "description": "ID of solver" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["title", "reward", "status", "userId", "createdAt"]
    },
    "StudySession": {
      "title": "StudySession",
      "description": "A Pomodoro study session",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of student" },
        "duration": { "type": "number", "description": "Duration in minutes" },
        "type": { "type": "string", "enum": ["focus", "break"], "description": "Session type" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["userId", "duration", "type", "createdAt"]
    },
    "Exam": {
      "title": "Exam",
      "description": "An upcoming exam for countdown",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of student" },
        "name": { "type": "string", "description": "Exam name" },
        "date": { "type": "number", "description": "Exam timestamp" }
      },
      "required": ["userId", "name", "date"]
    }
  },
  "firestore": {
    "/topics/{topicId}": {
      "schema": { "$ref": "Topic" },
      "description": "Community topics"
    },
    "/topic_members/{memberId}": {
      "schema": { "$ref": "TopicMember" },
      "description": "Topic memberships"
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "Message" },
      "description": "Topic messages"
    },
    "/reactions/{reactionId}": {
      "schema": { "$ref": "Reaction" },
      "description": "Message reactions"
    },
    "/mock_tests/{testId}": {
      "schema": { "$ref": "MockTest" },
      "description": "Mock exams"
    },
    "/test_results/{resultId}": {
      "schema": { "$ref": "TestResult" },
      "description": "Mock exam results"
    },
    "/bounties/{bountyId}": {
      "schema": { "$ref": "Bounty" },
      "description": "Doubt bounties"
    },
    "/study_sessions/{sessionId}": {
      "schema": { "$ref": "StudySession" },
      "description": "Pomodoro sessions"
    },
    "/exams/{examId}": {
      "schema": { "$ref": "Exam" },
      "description": "Upcoming exams"
    },
    "/whiteboard_data/{sessionId}": {
      "schema": { "type": "object", "properties": { "lines": { "type": "array" } } },
      "description": "Collaborative whiteboard data"
    }
  }
}
